<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤 マイページ"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="24dp"/>

        <!-- 学習メニュー -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚 学習メニュー"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔁 復習問題"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnUnanswered"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❓ 未回答・未チェック問題"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnWordBook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📚 単語・公式帳"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#FF5722"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnQuestionEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📝 問題を追加・管理"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#00897B"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <!-- 一問一答管理 アコーディオン -->
        <LinearLayout
            android:id="@+id/headerOneQSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#E8F5E9"
            android:padding="14dp"
            android:layout_marginBottom="2dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📋 一問一答管理"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"/>

            <TextView
                android:id="@+id/tvOneQToggleIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶"
                android:textSize="16sp"
                android:textColor="#2E7D32"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/containerOneQSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#F1F8E9"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnAddNewOneQ"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="➕ 新規追加"
                android:textSize="14sp"
                android:padding="12dp"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/listOneQContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>

        <!-- 成績・履歴 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 成績・履歴"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnCheckStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ チェック状態"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅 学習履歴"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnAchievement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏆 達成度"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnScoreByExam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📝 試験ごとの成績"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#607D8B"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnBackHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏠 ホームに戻る"
            android:textSize="16sp"
            android:padding="14dp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>