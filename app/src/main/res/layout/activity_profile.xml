<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤 マイページ"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="24dp"/>

        <!-- 学習メニュー -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚 学習メニュー"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔁 復習問題"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnUnanswered"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❓ 未回答・未チェック問題"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnWordBook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📚 単語・公式帳"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#FF5722"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnQuestionEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📝 問題を追加・管理"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#00897B"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <!-- 成績・履歴 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 成績・履歴"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnCheckStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ チェック状態"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅 学習履歴"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnAchievement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏆 達成度"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnScoreByExam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📝 試験ごとの成績"
            android:textSize="15sp"
            android:padding="14dp"
            android:backgroundTint="#607D8B"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnBackHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏠 ホームに戻る"
            android:textSize="16sp"
            android:padding="14dp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>