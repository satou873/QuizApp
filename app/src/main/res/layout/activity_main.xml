<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvQuestionNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="問題 1 / 5"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="問題文がここに入ります"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnChoice0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="選択肢1"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnChoice1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="選択肢2"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnChoice2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="選択肢3"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnChoice3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="選択肢4"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <!-- 解答ボタン -->
        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="解答する"
            android:textSize="18sp"
            android:padding="16dp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:enabled="false"
            android:layout_marginBottom="8dp"/>

        <!-- ホーム・途中保存ボタン行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🏠 ホーム"
                android:textSize="13sp"
                android:padding="10dp"
                android:backgroundTint="#607D8B"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💾 途中保存"
                android:textSize="13sp"
                android:padding="10dp"
                android:backgroundTint="#9C27B0"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

        <!-- 正解・不正解 表示 -->
        <TextView
            android:id="@+id/tvAnswerResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="12dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- 解説エリア -->
        <LinearLayout
            android:id="@+id/layoutExplanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📖 解説"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvExplanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="解説がここに入ります"
                android:textSize="16sp"
                android:textColor="#555555"/>

        </LinearLayout>

        <!-- 関連単語・公式エリア -->
        <LinearLayout
            android:id="@+id/layoutWordBook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚 関連する単語・公式"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#E65100"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:id="@+id/wordBookContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>

        <!-- 4段階チェックエリア -->
        <LinearLayout
            android:id="@+id/layoutCheckLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝 この問題の理解度は？"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnCheckPerfect"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💪 覚えた"
                    android:textSize="12sp"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnCheckGood"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="😊 まあまあ"
                    android:textSize="12sp"
                    android:backgroundTint="#2196F3"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnCheckPoor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🤔 微妙"
                    android:textSize="12sp"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnCheckForgot"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="😢 忘れた"
                    android:textSize="12sp"
                    android:backgroundTint="#F44336"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>
        </LinearLayout>

        <!-- 次の問題ボタン -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="次の問題 →"
            android:textSize="18sp"
            android:padding="16dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>